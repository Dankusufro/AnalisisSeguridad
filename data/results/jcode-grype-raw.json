nerate_cb, and set_stateless_cookie_generate_cb forwarded the user closure's returned usize directly to OpenSSL without checking it against the &mut [u8] that was handed to the closure. This can lead to buffer overflows and other unintended consequences. This vulnerability is fixed in 0.10.78.","cvss":[{"source":"nvd@nist.gov","type":"Primary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:H/A:H","metrics":{"baseScore":9.8,"exploitabilityScore":3.9,"impactScore":5.9},"vendorMetadata":{}},{"source":"security-advisories@github.com","type":"Secondary","version":"4.0","vector":"CVSS:4.0/AV:N/AC:L/AT:P/PR:N/UI:N/VC:H/VI:N/VA:L/SC:N/SI:N/SA:N/E:X/CR:X/IR:X/AR:X/MAV:X/MAC:X/MAT:X/MPR:X/MUI:X/MVC:X/MVI:X/MVA:X/MSC:X/MSI:X/MSA:X/S:X/AU:X/R:X/V:X/RE:X/U:X","metrics":{"baseScore":8.3},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-41898","epss":0.00057,"percentile":0.17753,"date":"2026-05-03"}],"cwes":[{"cve":"CVE-2026-41898","cwe":"CWE-126","source":"security-advisories@github.com","type":"Primary"},{"cve":"CVE-2026-41898","cwe":"CWE-130","source":"security-advisories@github.com","type":"Primary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"rust-matcher","searchedBy":{"language":"rust","namespace":"github:language:rust","package":{"name":"openssl","version":"0.10.75"}},"found":{"vulnerabilityID":"GHSA-hppc-g8h3-xhp3","versionConstraint":">=0.9.24,<0.10.78 (unknown)"},"fix":{"suggestedVersion":"0.10.78"}}],"artifact":{"id":"56042de9d1010851","name":"openssl","version":"0.10.75","type":"rust-crate","locations":[{"path":"/Cargo.lock","accessPath":"/Cargo.lock","annotations":{"evidence":"primary"}}],"language":"rust","licenses":[],"cpes":["cpe:2.3:a:openssl:openssl:0.10.75:*:*:*:*:*:*:*"],"purl":"pkg:cargo/openssl@0.10.75","upstreams":[]}},{"vulnerability":{"id":"GHSA-pqf5-4pqq-29f5","dataSource":"https://github.com/advisories/GHSA-pqf5-4pqq-29f5","namespace":"github:language:rust","severity":"High","urls":["https://github.com/rust-openssl/rust-openssl/security/advisories/GHSA-pqf5-4pqq-29f5","https://github.com/rust-openssl/rust-openssl/pull/2606","https://github.com/rust-openssl/rust-openssl/commit/09b425e5f59a2466d806e71a83a9a449c914c596","https://github.com/rust-openssl/rust-openssl/releases/tag/openssl-v0.10.78","https://nvd.nist.gov/vuln/detail/CVE-2026-41676"],"description":"rust-openssl: Deriver::derive and PkeyCtxRef::derive can overflow short buffers on OpenSSL 1.1.1","cvss":[{"type":"Secondary","version":"4.0","vector":"CVSS:4.0/AV:N/AC:L/AT:P/PR:N/UI:N/VC:H/VI:H/VA:H/SC:N/SI:N/SA:N/E:U","metrics":{"baseScore":7.2},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-41676","epss":0.0006,"percentile":0.18627,"date":"2026-05-03"}],"cwes":[{"cve":"CVE-2026-41676","cwe":"CWE-131","source":"security-advisories@github.com","type":"Primary"},{"cve":"CVE-2026-41676","cwe":"CWE-787","source":"security-advisories@github.com","type":"Primary"}],"fix":{"versions":["0.10.78"],"state":"fixed","available":[{"version":"0.10.78","date":"2026-04-23","kind":"first-observed"}]},"advisories":[],"risk":0.04409999999999999},"relatedVulnerabilities":[{"id":"CVE-2026-41676","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-41676","namespace":"nvd:cpe","severity":"Critical","urls":["https://github.com/rust-openssl/rust-openssl/security/advisories/GHSA-pqf5-4pqq-29f5"],"description":"rust-openssl provides OpenSSL bindings for the Rust programming language.  From 0.9.27 to before 0.10.78, Deriver::derive (and PkeyCtxRef::derive) sets len = buf.len() and passes it as the in/out length to EVP_PKEY_derive, relying on OpenSSL to honor it. On OpenSSL 1.1.x, X25519, X448, DH and HKDF-extract ignore the incoming *keylen, unconditionally writing the full shared secret (32/56/prime-size bytes). A caller passing a short slice gets a heap/stack overflow from safe code. OpenSSL 3.x providers do check, so this only impacts older OpenSSL. This vulnerability is fixed in 0.10.78.","cvss":[{"source":"nvd@nist.gov","type":"Primary","version"