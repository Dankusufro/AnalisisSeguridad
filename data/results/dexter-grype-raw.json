s, which will then execute during object decoding using that definition. Versions 8.0.1 and 7.5.5 patch the issue.","cvss":[{"source":"nvd@nist.gov","type":"Primary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:H/A:H","metrics":{"baseScore":9.8,"exploitabilityScore":3.9,"impactScore":5.9},"vendorMetadata":{}},{"source":"security-advisories@github.com","type":"Secondary","version":"4.0","vector":"CVSS:4.0/AV:N/AC:L/AT:N/PR:L/UI:N/VC:H/VI:H/VA:H/SC:H/SI:H/SA:H/E:X/CR:X/IR:X/AR:X/MAV:X/MAC:X/MAT:X/MPR:X/MUI:X/MVC:X/MVI:X/MVA:X/MSC:X/MSI:X/MSA:X/S:X/AU:X/R:X/V:X/RE:X/U:X","metrics":{"baseScore":9.4},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-41242","epss":0.00061,"percentile":0.18848,"date":"2026-05-03"}],"cwes":[{"cve":"CVE-2026-41242","cwe":"CWE-94","source":"security-advisories@github.com","type":"Primary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"javascript-matcher","searchedBy":{"language":"javascript","namespace":"github:language:javascript","package":{"name":"protobufjs","version":"7.5.4"}},"found":{"vulnerabilityID":"GHSA-xq3m-2v4x-88gg","versionConstraint":"<7.5.5 (semantic)"},"fix":{"suggestedVersion":"7.5.5"}}],"artifact":{"id":"946a5955ce210b0d","name":"protobufjs","version":"7.5.4","type":"npm","locations":[{"path":"/package-lock.json","accessPath":"/package-lock.json","annotations":{"evidence":"primary"}}],"language":"javascript","licenses":["BSD-3-Clause"],"cpes":["cpe:2.3:a:protobufjs_project:protobufjs:7.5.4:*:*:*:*:node.js:*:*"],"purl":"pkg:npm/protobufjs@7.5.4","upstreams":[]}},{"vulnerability":{"id":"GHSA-j47w-4g3g-c36v","dataSource":"https://github.com/advisories/GHSA-j47w-4g3g-c36v","namespace":"github:language:javascript","severity":"Medium","urls":["https://github.com/sindresorhus/file-type/security/advisories/GHSA-j47w-4g3g-c36v","https://github.com/sindresorhus/file-type/commit/a155cd71323279de173c54e8c530d300d3854fdd","https://github.com/sindresorhus/file-type/releases/tag/v21.3.2","https://nvd.nist.gov/vuln/detail/CVE-2026-32630","https://github.com/sindresorhus/file-type/commit/399b0f156063f5aeb1c124a7fd61028f3ea7c124"],"description":"file-type: ZIP Decompression Bomb DoS via [Content_Types].xml entry","cvss":[{"type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:L","metrics":{"baseScore":5.3,"exploitabilityScore":3.9,"impactScore":1.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-32630","epss":0.00075,"percentile":0.22434,"date":"2026-05-03"}],"cwes":[{"cve":"CVE-2026-32630","cwe":"CWE-409","source":"security-advisories@github.com","type":"Secondary"}],"fix":{"versions":["21.3.2"],"state":"fixed","available":[{"version":"21.3.2","date":"2026-03-14","kind":"first-observed"}]},"advisories":[],"risk":0.03862500000000001},"relatedVulnerabilities":[{"id":"CVE-2026-32630","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-32630","namespace":"nvd:cpe","severity":"Medium","urls":["https://github.com/sindresorhus/file-type/commit/399b0f156063f5aeb1c124a7fd61028f3ea7c124","https://github.com/sindresorhus/file-type/security/advisories/GHSA-j47w-4g3g-c36v"],"description":"file-type detects the file type of a file, stream, or data. From 20.0.0 to 21.3.1, a crafted ZIP file can trigger excessive memory growth during type detection in file-type when using fileTypeFromBuffer(), fileTypeFromBlob(), or fileTypeFromFile(). The ZIP inflate output limit is enforced for stream-based detection, but not for known-size inputs. As a result, a small compressed ZIP can cause file-type to inflate and process a much larger payload while probing ZIP-based formats such as OOXML. This vulnerability is fixed in 21.3.2.","cvss":[{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:L","metrics":{"baseScore":5.3,"exploitabilityScore":3.9,"impactScore":1.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-32630","epss":0.00075,"percentile":0.22434,"date":"2026-05-03"}],"cwes":[{"cve":"CVE-2026-32630","cwe":"CWE-409","source":"security-advisories@github.com","type":"Secondary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"javascript-matcher","searchedBy":{"language":"javascript","namespace":"github:language:javascript","package":{"name":"file-type","version":"21.3.0"}},"found":{"vulnerabilityID":"GHSA-j47w-4g3g-c36v","versionConstraint":">=20.0.0,<=21.3.1 (semantic)"},"fix":{"suggestedVersion":"21.3.2"}}],"artifact":{"id":"273150c3041b93d0","name":"file-type","version":"21.3.0","type":"npm","locations":[{"path":"/package-lock.json","accessPath":"/package-lock.json","annotations":{"evidence":"primary"}}],"language":"javascript","licenses":["MIT"],"cpes":["cpe:2.3:a:sindresorhus:file-type:21.3.0:*:*:*:*:node.js:*:*"],"purl":"pkg:npm/file-type@21.3.0","upstreams":[]}},{"vulnerability":{"id":"GHSA-fw9q-39r9-c252","dataSource":"https://github.com/advisories/GHSA-fw9q-39r9-c252","namespace":"github:language:javascript","severity":"Medium","urls":["https://github.com/langchain-ai/langsmith-sdk/security/advisories/GHSA-fw9q-39r9-c252","https://github.com/langchain-ai/langsmith-sdk/pull/2690","https://github.com/langchain-ai/langsmith-sdk/commit/31d3c3aec02892f4312baae112f817d6b2f0ebe3","https://nvd.nist.gov/vuln/detail/CVE-2026-40190"],"description":"LangSmith Client SDKs has Prototype Pollution in langsmith-sdk via Incomplete `__proto__` Guard in Internal lodash `set()`","cvss":[{"type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L","metrics":{"baseScore":5.6,"exploitabilityScore":2.3,"impactScore":3.4},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-40190","epss":0.00052,"percentile":0.16197,"date":"2026-05-03"}],"cwes":[{"cve":"CVE-2026-40190","cwe":"CWE-1321","source":"security-advisories@github.com","type":"Primary"}],"fix":{"versions":["0.5.18"],"state":"fixed","available":[{"version":"0.5.18","date":"2026-04-11","kind":"first-observed"}]},"advisories":[],"risk":0.027559999999999998},"relatedVulnerabilities":[{"id":"CVE-2026-40190","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-40190","namespace":"nvd:cpe","severity":"Medium","urls":["https://github.com/langchain-ai/langsmith-sdk/security/advisories/GHSA-fw9q-39r9-c252"],"description":"LangSmith Client SDKs provide SDK's for interacting with the LangSmith platform. Prior to 0.5.18, the LangSmith JavaScript/TypeScript SDK (langsmith) contains an incomplete prototype pollution fix in its internally vendored lodash set() utility. The baseAssignValue() function only guards against the __proto__ key, but fails to prevent traversal via constructor.prototype. This allows an attacker who controls keys in data processed by the createAnonymizer() API to pollute Object.prototype, affecting all objects in the Node.js process. This vulnerability is fixed in 0.5.18.","cvss":[{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L","metrics":{"baseScore":5.6,"exploitabilityScore":2.3,"impactScore":3.4},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-40190","epss":0.00052,"percentile":0.16197,"date":"2026-05-03"}],"cwes":[{"cve":"CVE-2026-40190","cwe":"CWE-1321","source":"security-advisories@github.com","type":"Primary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"javascript-matcher","searchedBy":{"language":"javascript","namespace":"github:language:javascript","package":{"name":"langsmith","version":"0.4.12"}},"found":{"vulnerabilityID":"GHSA-fw9q-39r9-c252","versionConstraint":"<=0.5.17 (semantic)"},"fix":{"suggestedVersion":"0.5.18"}}],"artifact":{"id":"fed083bc3b2fb838","name":"langsmith","version":"0.4.12","type":"npm","locations":[{"path":"/package-lock.json","accessPath":"/package-lock.json","annotations":{"evidence":"primary"}}],"language":"javascript","licenses":["MIT"],"cpes":["cpe:2.3:a:langsmith:langsmith:0.4.12:*:*:*:*:*:*:*"],"purl":"pkg:npm/langsmith@0.4.12","upstreams":[]}},{"vulnerability":{"id":"GHSA-fw9q-39r9-c252","dataSource":"https://github.com/advisories/GHSA-fw9q-39r9-c252","namespace":"github:language:javascript","severity":"Medium","urls":["https://github.com/langchain-ai/langsmith-sdk/security/advisories/GHSA-fw9q-39r9-c252","https://github.com/langchain-ai/langsmith-sdk/pull/2690","https://github.com/langchain-ai/langsmith-sdk/commit/31d3c3aec02892f4312baae112f817d6b2f0ebe3","https://nvd.nist.gov/vuln/detail/CVE-2026-40190"],"description":"LangSmith Client SDKs has Prototype Pollution in langsmith-sdk via Incomplete `__proto__` Guard in Internal lodash `set()`","cvss":[{"type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L","metrics":{"baseScore":5.6,"exploitabilityScore":2.3,"impactScore":3.4},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-40190","epss":0.00052,"percentile":0.16197,"date":"2026-05-03"}],"cwes":[{"cve":"CVE-2026-40190","cwe":"CWE-1321","source":"security-advisories@github.com","type":"Primary"}],"fix":{"versions":["0.5.18"],"state":"fixed","available":[{"version":"0.5.18","date":"2026-04-11","kind":"first-observed"}]},"advisories":[],"risk":0.027559999999999998},"relatedVulnerabilities":[{"id":"CVE-2026-40190","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-40190","namespace":"nvd:cpe","severity":"Medium","urls":["https://github.com/langchain-ai/langsmith-sdk/security/advisories/GHSA-fw9q-39r9-c252"],"description":"LangSmith Client SDKs provide SDK's for interacting with the LangSmith platform. Prior to 0.5.18, the LangSmith JavaScript/TypeScript SDK (langsmith) contains an incomplete prototype pollution fix in its internally vendored lodash set() utility. The baseAssignValue() function only guards against the __proto__ key, but fails to prevent traversal via constructor.prototype. This allows an attacker who controls keys in data processed by the createAnonymizer() API to pollute Object.prototype, affecting all objects in the Node.js process. This vulnerability is fixed in 0.5.18.","cvss":[{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L","metrics":{"baseScore":5.6,"exploitabilityScore":2.3,"impactScore":3.4},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-40190","epss":0.00052,"percentile":0.16197,"date":"2026-05-03"}],"cwes":[{"cve":"CVE-2026-40190","cwe":"CWE-1321","source":"security-advisories@github.com","type":"Primary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"javascript-matcher","searchedBy":{"language":"javascript","namespace":"github:language:javascript","package":{"name":"langsmith","version":"0.5.13"}},"found":{"vulnerabilityID":"GHSA-fw9q-39r9-c252","versionConstraint":"<=0.5.17 (semantic)"},"fix":{"suggestedVersion":"0.5.18"}}],"artifact":{"id":"7f3ed5fb7f3459ff","name":"langsmith","version":"0.5.13","type":"npm","locations":[{"path":"/package-lock.json","accessPath":"/package-lock.json","annotations":{"evidence":"primary"}}],"language":"javascript","licenses":["MIT"],"cpes":["cpe:2.3:a:langsmith:langsmith:0.5.13:*:*:*:*:*:*:*"],"purl":"pkg:npm/langsmith@0.5.13","upstreams":[]}},{"vulnerability":{"id":"GHSA-rr7j-v2q5-chgv","dataSource":"https://github.com/advisories/GHSA-rr7j-v2q5-chgv","namespace":"github:language:javascript","severity":"Medium","urls":["https://github.com/langchain-ai/langsmith-sdk/security/advisories/GHSA-rr7j-v2q5-chgv","https://nvd.nist.gov/vuln/detail/CVE-2026-41182"],"description":"LangSmith SDK: Streaming token events bypass output redaction","cvss":[{"type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:L/I:N/A:N","metrics":{"baseScore":5.3,"exploitabilityScore":3.9,"impactScore":1.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-41182","epss":0.00036,"percentile":0.1062,"date":"2026-05-03"}],"cwes":[{"cve":"CVE-2026-41182","cwe":"CWE-200","source":"security-advisories@github.com","type":"Primary"},{"cve":"CVE-2026-41182","cwe":"CWE-359","source":"security-advisories@github.com","type":"Primary"},{"cve":"CVE-2026-41182","cwe":"CWE-532","source":"security-advisories@github.com","type":"Primary"}],"fix":{"versions":["0.5.19"],"state":"fixed","available":[{"version":"0.5.19","date":"2026-04-16","kind":"first-observed"}]},"advisories":[],"risk":0.01854},"relatedVulnerabilities":[{"id":"CVE-2026-41182","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-41182","namespace":"nvd:cpe","severity":"Medium","urls":["https://github.com/langchain-ai/langsmith-sdk/security/advisories/GHSA-rr7j-v2q5-chgv"],"description":"LangSmith Client SDKs provide SDK's for interacting with the LangSmith platform. Prior to version 0.5.19 of the JavaScript SDK and version 0.7.31 of the Python SDK, the LangSmith SDK's output redaction controls (hideOutputs in JS, hide_outputs in Python) do not apply to streaming token events. When an LLM run produces streaming output, each chunk is recorded as a new_token event containing the raw token value. These events bypass the redaction pipeline entirely — prepareRunCreateOrUpdateInputs (JS) and _hide_run_outputs (Python) only process the inputs and outputs fields on a run, never the events array. As a result, applications relying on output redaction to prevent sensitive LLM output from being stored in LangSmith will still leak the full streamed content via run events. Version 0.5.19 of the JavaScript SDK and version 0.7.31 of the Python SDK fix the issue.","cvss":[{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:L/I:N/A:N","metrics":{"baseScore":5.3,"exploitabilityScore":3.9,"impactScore":1.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-41182","epss":0.00036,"percentile":0.1062,"date":"2026-05-03"}],"cwes":[{"cve":"CVE-2026-41182","cwe":"CWE-200","source":"security-advisories@github.com","type":"Primary"},{"cve":"CVE-2026-41182","cwe":"CWE-359","source":"security-advisories@github.com","type":"Primary"},{"cve":"CVE-2026-41182","cwe":"CWE-532","source":"security-advisories@github.com","type":"Primary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"javascript-matcher","searchedBy":{"language":"javascript","namespace":"github:language:javascript","package":{"name":"langsmith","version":"0.4.12"}},"found":{"vulnerabilityID":"GHSA-rr7j-v2q5-chgv","versionConstraint":"<=0.5.18 (semantic)"},"fix":{"suggestedVersion":"0.5.19"}}],"artifact":{"id":"fed083bc3b2fb838","name":"langsmith","version":"0.4.12","type":"npm","locations":[{"path":"/package-lock.json","accessPath":"/package-lock.json","annotations":{"evidence":"primary"}}],"language":"javascript","licenses":["MIT"],"cpes":["cpe:2.3:a:langsmith:langsmith:0.4.12:*:*:*:*:*:*:*"],"purl":"pkg:npm/langsmith@0.4.12","upstreams":[]}},{"vulnerability":{"id":"GHSA-rr7j-v2q5-chgv","dataSource":"https://github.com/advisories/GHSA-rr7j-v2q5-chgv","namespace":"github:language:javascript","severity":"Medium","urls":["https://github.com/langchain-ai/langsmith-sdk/security/advisories/GHSA-rr7j-v2q5-chgv","https://nvd.nist.gov/vuln/detail/CVE-2026-41182"],"description":"LangSmith SDK: Streaming token events bypass output redaction","cvss":[{"type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:L/I:N/A:N","metrics":{"baseScore":5.3,"exploitabilityScore":3.9,"impactScore":1.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-41182","epss":0.00036,"percentile":0.1062,"date":"2026-05-03"}],"cwes":[{"cve":"CVE-2026-41182","cwe":"CWE-200","source":"security-advisories@github.com","type":"Primary"},{"cve":"CVE-2026-41182","cwe":"CWE-359","source":"security-advisories@github.com","type":"Primary"},{"cve":"CVE-2026-41182","cwe":"CWE-532","source":"security-advisories@github.com","type":"Primary"}],"fix":{"versions":["0.5.19"],"state":"fixed","available":[{"version":"0.5.19","date":"2026-04-16","kind":"first-observed"}]},"advisories":[],"risk":0.01854},"relatedVulnerabilities":[{"id":"CVE-2026-41182","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-41182","namespace":"nvd:cpe","severity":"Medium","urls":["https://github.com/langchain-ai/langsmith-sdk/security/advisories/GHSA-rr7j-v2q5-chgv"],"description":"LangSmith Client SDKs provide SDK's for interacting with the LangSmith platform. Prior to version 0.5.19 of the JavaScript SDK and version 0.7.31 of the Python SDK, the LangSmith SDK's output redaction controls (hideOutputs in JS, hide_outputs in Python) do not apply to streaming token events. When an LLM run produces streaming output, each chunk is recorded as a new_token event containing the raw token value. These events bypass the redaction pipeline entirely — prepareRunCreateOrUpdateInputs (JS) and _hide_run_outputs (Python) only process the inputs and outputs fields on a run, never the events array. As a result, applications relying on output redaction to prevent sensitive LLM output from being stored in LangSmith will still leak the full streamed content via run events. Version 0.5.19 of the JavaScript SDK and version 0.7.31 of the Python SDK fix the issue.","cvss":[{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:L/I:N/A:N","metrics":{"baseScore":5.3,"exploitabilityScore":3.9,"impactScore":1.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-41182","epss":0.00036,"percentile":0.1062,"date":"2026-05-03"}],"cwes":[{"cve":"CVE-2026-41182","cwe":"CWE-200","source":"security-advisories@github.com","type":"Primary"},{"cve":"CVE-2026-41182","cwe":"CWE-359","source":"security-advisories@github.com","type":"Primary"},{"cve":"CVE-2026-41182","cwe":"CWE-532","source":"security-advisories@github.com","type":"Primary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"javascript-matcher","searchedBy":{"language":"javascript","namespace":"github:language:javascript","package":{"name":"langsmith","version":"0.5.13"}},"found":{"vulnerabilityID":"GHSA-rr7j-v2q5-chgv","versionConstraint":"<=0.5.18 (semantic)"},"fix":{"suggestedVersion":"0.5.19"}}],"arti