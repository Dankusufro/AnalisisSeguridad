eader has a size field of zero, the parser enters an infinite loop. The payload value becomes negative (-24), causing tokenizer.ignore(payload) to move the read position backwards, so the same sub-header is read repeatedly forever. Any application that uses file-type to detect the type of untrusted/attacker-controlled input is affected. An attacker can stall the Node.js event loop with a 55-byte payload. Fixed in version 21.3.1.","cvss":[{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:L","metrics":{"baseScore":5.3,"exploitabilityScore":3.9,"impactScore":1.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-31808","epss":0.0003,"percentile":0.08586,"date":"2026-05-03"}],"cwes":[{"cve":"CVE-2026-31808","cwe":"CWE-835","source":"security-advisories@github.com","type":"Primary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"javascript-matcher","searchedBy":{"language":"javascript","namespace":"github:language:javascript","package":{"name":"file-type","version":"21.3.0"}},"found":{"vulnerabilityID":"GHSA-5v7r-6r5c-r473","versionConstraint":">=13.0.0,<21.3.1 (semantic)"},"fix":{"suggestedVersion":"21.3.1"}}],"artifact":{"id":"273150c3041b93d0","name":"file-type","version":"21.3.0","type":"npm","locations":[{"path":"/package-lock.json","accessPath":"/package-lock.json","annotations":{"evidence":"primary"}}],"language":"javascript","licenses":["MIT"],"cpes":["cpe:2.3:a:sindresorhus:file-type:21.3.0:*:*:*:*:node.js:*:*"],"purl":"pkg:npm/file-type@21.3.0","upstreams":[]}},{"vulnerability":{"id":"GHSA-v6c2-xwv6-8xf7","dataSource":"https://github.com/advisories/GHSA-v6c2-xwv6-8xf7","namespace":"github:language:javascript","severity":"High","urls":["https://github.com/Borewit/music-metadata/security/advisories/GHSA-v6c2-xwv6-8xf7","https://github.com/Borewit/music-metadata/releases/tag/v11.12.3","https://nvd.nist.gov/vuln/detail/CVE-2026-32256"],"description":"music-metadata has an infi